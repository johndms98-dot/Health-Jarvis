# Copy to .env.local and fill in your values.
# Find your Mac's local IP: System Settings > Wi-Fi > Details > IP Address

EXPO_PUBLIC_MAC_HOST=192.168.1.XXX

# Withings (optional — for weight/body composition)
# Register free app at developer.withings.com, set redirect URI to: healthdashboard://withings-auth
EXPO_PUBLIC_WITHINGS_CLIENT_ID=
EXPO_PUBLIC_WITHINGS_CLIENT_SECRET=

# No Anthropic API key needed — AI insights run via Ollama (llama3.1:8b) on your Mac. 100% free.
